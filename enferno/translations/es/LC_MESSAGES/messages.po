#: enferno/templates/setup_wizard.html:247
msgid "Minimum required length for passwords."
msgstr "Longitud mínima necesaria para las contraseñas."

#: enferno/templates/setup_wizard.html:253
msgid ""
"Bayanat uses zxcvbn password strength estimator to calculate a password "
"score. 'Medium' corresponds to a zxcvbn score of 2 and is suitable for "
"offline Bayanat installation. 'Strong' corresponds to a score of 3, we "
"recommend this setting for online Bayanat installations. 'Very Strong' "
"corresponds to a zxcvbn score of 4 and offers the highest level of "
"protection."
msgstr ""
"Bayanat utiliza el estimador de seguridad de contraseñas zxcvbn para "
"calcular la puntuación de una contraseña. \"Media\" corresponde a una "
"puntuación de zxcvbn de 2 y es adecuada para instalaciones de Bayanat sin"
" conexión. \"Fuerte\" corresponde a una puntuación de 3, recomendamos "
"esta configuración para instalaciones de Bayanat en línea. \"Muy fuerte\""
" corresponde a una puntuación zxcvbn de 4 y ofrece el máximo nivel de "
"protección."

