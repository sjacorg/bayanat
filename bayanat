#!/usr/bin/env bash
#
# bayanat - CLI for installing and managing Bayanat
# Usage: bayanat <command> [options]
#
set -euo pipefail

readonly SCRIPT_VERSION="1.2.0"
readonly BAYANAT_ROOT="/opt/bayanat"
readonly RELEASES_DIR="$BAYANAT_ROOT/releases"
readonly SHARED_DIR="$BAYANAT_ROOT/shared"
readonly LOGS_DIR="$BAYANAT_ROOT/logs"
readonly CURRENT_LINK="$BAYANAT_ROOT/current"
readonly DEFAULT_REPO="sjacorg/bayanat"
readonly GIT_URL="https://github.com/${BAYANAT_REPO:-$DEFAULT_REPO}.git"
readonly APP_USER="bayanat"

# --- Logging ---

log()   { printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$1"; }
warn()  { printf '[%s] WARN: %s\n' "$(date '+%H:%M:%S')" "$1" >&2; }
die()   {
    printf '[%s] ERROR: %s\n' "$(date '+%H:%M:%S')" "$1" >&2
    [[ -n "${2:-}" ]] && printf '[%s] FIX: %s\n' "$(date '+%H:%M:%S')" "$2" >&2
    exit 1
}

require_root() { [[ $EUID -eq 0 ]] || die "Must run as root"; }

# --- Preflight ---

preflight_checks() {
    # OS
    [[ -f /etc/os-release ]] || die "Cannot detect OS (missing /etc/os-release)"
    local os_id os_ver
    os_id=$(grep '^ID=' /etc/os-release | cut -d= -f2)
    os_ver=$(grep '^VERSION_ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
    [[ "$os_id" == "ubuntu" ]] || die "Unsupported OS: $os_id (need Ubuntu)"
    [[ "${os_ver%%.*}" -ge 22 ]] || die "Ubuntu $os_ver is too old (need 22.04+)"

    # Architecture
    local arch
    arch=$(uname -m)
    [[ "$arch" == "x86_64" || "$arch" == "aarch64" ]] \
        || die "Unsupported architecture: $arch"
    log "System: Ubuntu $os_ver ($arch)"

    # Disk space (need 2GB free on /opt)
    local free_kb
    free_kb=$(df --output=avail /opt 2>/dev/null | tail -1 | tr -d ' ')
    if [[ -n "$free_kb" ]] && [[ "$free_kb" -lt 2097152 ]]; then
        die "Need at least 2GB free on /opt (have $((free_kb / 1024))MB)"
    fi

    # Network
    if ! curl -sfSL --max-time 5 -o /dev/null https://github.com; then
        die "Cannot reach github.com. Check your network."
    fi
}

# --- Helpers ---

latest_remote_tag() {
    git ls-remote --tags --refs --sort=-version:refname "$GIT_URL" \
        | head -1 | sed 's/.*refs\/tags\///'
}

current_version() {
    [[ -L "$CURRENT_LINK" ]] || return 1
    basename "$(readlink "$CURRENT_LINK")"
}

flask_run() {
    local version="$1"; shift
    sudo -u "$APP_USER" \
        env FLASK_APP=run.py \
        /usr/local/bin/uv run \
        --directory "$RELEASES_DIR/$version" \
        flask "$@"
}

swap_symlink() {
    local target="$1"
    ln -sfn "$target" "$CURRENT_LINK.tmp"
    mv -Tf "$CURRENT_LINK.tmp" "$CURRENT_LINK"
}

# --- Snapshot helpers ---

SNAPSHOT_RETENTION_DAYS="${BAYANAT_SNAPSHOT_RETENTION_DAYS:-30}"
SNAPSHOT_RETENTION_COUNT=5

_pg_env() {
    # Emits pg_dump / pg_restore env from shared/.env. All callers must
    # `eval "$(_pg_env)"` in a subshell.
    local env_file="$SHARED_DIR/.env"
    [[ -f "$env_file" ]] || die "missing $env_file"
    grep -E '^(POSTGRES_HOST|POSTGRES_PORT|POSTGRES_USER|POSTGRES_PASSWORD|POSTGRES_DB)=' \
        "$env_file" | sed 's/^/export /'
}

snapshot_pg_dump() {
    # $1 = previous tag, $2 = target tag
    # Writes shared/backups/pre-<prev>-to-<target>-<ts>.dump via .partial rename.
    local prev="$1" target="$2"
    local ts name partial final
    ts=$(date -u +%Y%m%d-%H%M)
    name="pre-${prev}-to-${target}-${ts}.dump"
    partial="$SHARED_DIR/backups/${name}.partial"
    final="$SHARED_DIR/backups/${name}"
    log "Taking pre-update snapshot: $name"
    (
        eval "$(_pg_env)"
        PGPASSWORD="${POSTGRES_PASSWORD:-}" \
            pg_dump -Fc \
                -h "${POSTGRES_HOST:-localhost}" \
                -p "${POSTGRES_PORT:-5432}" \
                -U "$POSTGRES_USER" \
                -f "$partial" \
                "$POSTGRES_DB"
    )
    mv -Tf "$partial" "$final"
    echo "$name"
}

prune_snapshots() {
    # Keep last $SNAPSHOT_RETENTION_COUNT snapshots OR last
    # $SNAPSHOT_RETENTION_DAYS days, whichever is greater.
    local backups="$SHARED_DIR/backups"
    [[ -d "$backups" ]] || return 0
    local cutoff_epoch
    cutoff_epoch=$(date -d "-${SNAPSHOT_RETENTION_DAYS} days" +%s 2>/dev/null \
        || date -v-"${SNAPSHOT_RETENTION_DAYS}"d +%s)
    local idx=0 name path mtime
    while IFS= read -r path; do
        idx=$((idx + 1))
        name=$(basename "$path")
        mtime=$(stat -c %Y "$path" 2>/dev/null || stat -f %m "$path")
        if [[ "$idx" -le "$SNAPSHOT_RETENTION_COUNT" ]]; then
            continue
        fi
        if [[ "$mtime" -lt "$cutoff_epoch" ]]; then
            log "Pruning snapshot: $name"
            rm -f "$path"
        fi
    done < <(ls -1t "$backups"/pre-*.dump 2>/dev/null || true)
}

list_snapshots() {
    local backups="$SHARED_DIR/backups"
    [[ -d "$backups" ]] || { echo "No snapshots directory."; return; }
    printf '%-60s %10s %20s\n' "NAME" "SIZE" "AGE"
    local name size mtime age
    while IFS= read -r path; do
        name=$(basename "$path")
        size=$(du -h "$path" | cut -f1)
        mtime=$(stat -c %Y "$path" 2>/dev/null || stat -f %m "$path")
        age="$(( ($(date +%s) - mtime) / 3600 ))h"
        printf '%-60s %10s %20s\n' "$name" "$size" "$age"
    done < <(ls -1t "$backups"/pre-*.dump 2>/dev/null || true)
}

restore_pg() {
    # $1 = snapshot basename (no path). Stops services, restores, starts services.
    local name="$1"
    local path="$SHARED_DIR/backups/$name"
    [[ -f "$path" ]] || die "snapshot not found: $path"
    log "Restoring $name (this will DROP and RECREATE tables)"
    read -r -p "Type 'yes' to confirm: " reply
    [[ "$reply" == "yes" ]] || die "aborted"
    systemctl stop bayanat bayanat-celery
    if ! (
        eval "$(_pg_env)"
        PGPASSWORD="${POSTGRES_PASSWORD:-}" \
            pg_restore --clean --if-exists \
                -h "${POSTGRES_HOST:-localhost}" \
                -p "${POSTGRES_PORT:-5432}" \
                -U "$POSTGRES_USER" \
                -d "$POSTGRES_DB" \
                "$path"
    ); then
        systemctl start bayanat bayanat-celery
        die "pg_restore failed; services restarted on existing DB"
    fi
    systemctl start bayanat bayanat-celery
    log "Restore complete"
}

# --- Step functions (each is idempotent) ---

_install_system_packages() {
    log "Installing system packages..."
    export DEBIAN_FRONTEND=noninteractive
    export NEEDRESTART_MODE=a
    apt-get update -qq
    apt-get install -y -qq \
        git postgresql postgresql-contrib postgis redis-server \
        python3 python3-dev build-essential \
        libpq-dev libxml2-dev libxslt1-dev libssl-dev libffi-dev \
        libjpeg-dev libzip-dev libimage-exiftool-perl ffmpeg curl wget jq
}

_install_uv() {
    if command -v uv &>/dev/null; then
        log "uv already installed: $(uv --version)"
        return 0
    fi
    log "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR=/usr/local/bin sh
    # Verify
    command -v uv &>/dev/null || die "uv installation failed"
    log "Installed: $(uv --version)"
}

_install_caddy_repo() {
    if command -v caddy &>/dev/null; then
        log "Caddy already installed"
        return 0
    fi
    log "Installing Caddy..."
    local keyring="/usr/share/keyrings/caddy-stable-archive-keyring.gpg"
    curl -fsSL 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' \
        | gpg --batch --yes --dearmor -o "$keyring"
    curl -fsSL 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' \
        > /etc/apt/sources.list.d/caddy-stable.list
    apt-get update -qq
    apt-get install -y -qq caddy
}

_setup_app_user() {
    if id "$APP_USER" &>/dev/null; then
        log "User $APP_USER already exists"
    else
        # Reuse existing group if left over from previous install
        if getent group "$APP_USER" &>/dev/null; then
            useradd -m -g "$APP_USER" "$APP_USER"
        else
            useradd -m "$APP_USER"
        fi
        log "Created user $APP_USER"
    fi
    usermod -aG "$APP_USER" caddy 2>/dev/null || true
}

_setup_database() {
    systemctl enable --now postgresql redis-server

    log "Setting up database..."
    sudo -u postgres createuser -s "$APP_USER" 2>/dev/null || true
    sudo -u postgres createdb bayanat -O "$APP_USER" 2>/dev/null || true

    # Configure pg_hba trust auth for app user
    local pg_hba
    pg_hba=$(find /etc/postgresql -name pg_hba.conf 2>/dev/null | head -1)
    [[ -n "$pg_hba" ]] || die "Cannot find pg_hba.conf"

    local rule="local   all             $APP_USER                                 trust"
    if grep -qF "$rule" "$pg_hba"; then
        log "pg_hba.conf already configured"
    else
        log "Configuring pg_hba.conf for $APP_USER"
        # Insert before the "local all all" catch-all, or append
        if grep -q "^local.*all.*all" "$pg_hba"; then
            sed -i "/^local.*all.*all/i $rule" "$pg_hba"
        else
            echo "$rule" >> "$pg_hba"
        fi
        systemctl reload postgresql
    fi
}

_create_directories() {
    mkdir -p "$RELEASES_DIR" "$SHARED_DIR/media" "$SHARED_DIR/backups" \
             "$LOGS_DIR"
}

_clone_release() {
    local tag="$1"
    local dest="$RELEASES_DIR/$tag"

    if [[ -d "$dest/.git" ]]; then
        if sudo -u "$APP_USER" git -C "$dest" rev-parse HEAD &>/dev/null; then
            log "Release $tag already cloned"
            return 0
        fi
        warn "Partial clone detected, removing $dest"
        rm -rf "$dest"
    elif [[ -d "$dest" ]]; then
        warn "Invalid release directory, removing $dest"
        rm -rf "$dest"
    fi

    log "Cloning $tag..."
    git clone --depth 1 --branch "$tag" "$GIT_URL" "$dest"
}

_generate_env() {
    local domain="$1"
    local force_https="False"
    [[ "$domain" != "localhost" ]] && force_https="True"

    cat > "$SHARED_DIR/.env" << EOF
FLASK_APP=run.py
FLASK_DEBUG=0

SECRET_KEY='$(openssl rand -base64 32)'
SECURITY_PASSWORD_SALT='$(openssl rand -base64 32)'

SECURITY_TOTP_SECRETS='$(openssl rand -base64 32)'
SECURITY_TWO_FACTOR=True
SECURITY_TWO_FACTOR_RESCUE_MAIL=''
SECURITY_TWO_FACTOR_AUTHENTICATOR_VALIDITY=90

SECURE_COOKIES=$force_https
FORCE_HTTPS=$force_https

LOG_DIR=$LOGS_DIR
BACKUPS_LOCAL_PATH=$SHARED_DIR/backups
EOF
}

_link_shared() {
    local tag="$1"
    local release="$RELEASES_DIR/$tag"

    [[ -f "$SHARED_DIR/.env" ]] && ln -sfn "$SHARED_DIR/.env" "$release/.env"

    if [[ -d "$release/enferno/media" ]] && [[ ! -L "$release/enferno/media" ]]; then
        rm -rf "$release/enferno/media"
    fi
    ln -sfn "$SHARED_DIR/media" "$release/enferno/media"
}

_install_deps() {
    local tag="$1"
    log "Installing Python dependencies..."
    sudo -u "$APP_USER" \
        /usr/local/bin/uv sync --frozen --python 3.12 \
        --directory "$RELEASES_DIR/$tag"
}

_init_database() {
    local tag="$1"
    log "Initializing database..."
    flask_run "$tag" create-db --create-exts
    flask_run "$tag" import-data

    # Stamp Alembic head only if this release has migrations
    if [[ -d "$RELEASES_DIR/$tag/migrations/versions" ]]; then
        log "Stamping Alembic baseline..."
        flask_run "$tag" db stamp head
    else
        log "No Alembic migrations in $tag, skipping stamp"
    fi
}

_install_uwsgi_config() {
    cat > "$SHARED_DIR/uwsgi-prod.ini" << EOF
[uwsgi]
virtualenv=.venv
module=run:app
master=true
processes=1
threads=2
http-socket=$CURRENT_LINK/bayanat.sock
chmod-socket=660
vacuum=true
buffer-size=8192
touch-reload=reload.ini
reload-mercy=5
worker-reload-mercy=3
EOF
}

_install_systemd() {
    cat > /etc/systemd/system/bayanat.service << EOF
[Unit]
Description=Bayanat web application
After=network.target postgresql.service redis.service

[Service]
User=$APP_USER
Group=$APP_USER
WorkingDirectory=$CURRENT_LINK
EnvironmentFile=$SHARED_DIR/.env
ExecStart=$CURRENT_LINK/.venv/bin/uwsgi --ini $SHARED_DIR/uwsgi-prod.ini
Restart=always
RestartSec=3
KillMode=mixed
KillSignal=SIGQUIT
TimeoutStopSec=10
Type=notify
NotifyAccess=all

[Install]
WantedBy=multi-user.target
EOF

    cat > /etc/systemd/system/bayanat-celery.service << EOF
[Unit]
Description=Bayanat Celery worker
After=network.target postgresql.service redis.service

[Service]
User=$APP_USER
Group=$APP_USER
WorkingDirectory=$CURRENT_LINK
EnvironmentFile=$SHARED_DIR/.env
ExecStart=$CURRENT_LINK/.venv/bin/celery -A enferno.tasks worker --autoscale 2,5 -B
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
EOF
}

_configure_caddy() {
    local domain="$1"

    if [[ "$domain" == "localhost" ]]; then
        cat > /etc/caddy/Caddyfile << 'EOF'
:80 {
    reverse_proxy unix//opt/bayanat/current/bayanat.sock
    handle_path /static/* {
        root * /opt/bayanat/current/enferno/static
        file_server
    }
    request_body {
        max_size 100MB
    }
}
EOF
    else
        cat > /etc/caddy/Caddyfile << EOF
$domain {
    reverse_proxy unix//opt/bayanat/current/bayanat.sock
    handle_path /static/* {
        root * /opt/bayanat/current/enferno/static
        file_server
    }
    request_body {
        max_size 100MB
    }
}
EOF
    fi
}

_install_sudoers() {
    cat > /etc/sudoers.d/bayanat << 'EOF'
bayanat ALL=(root) NOPASSWD: /usr/local/bin/bayanat update
bayanat ALL=(root) NOPASSWD: /usr/local/bin/bayanat status
bayanat ALL=(root) NOPASSWD: /usr/bin/systemctl restart bayanat-celery
EOF
    chmod 440 /etc/sudoers.d/bayanat
}

# --- Install ---

cmd_install() {
    local domain="${1:-localhost}"
    require_root
    preflight_checks

    log "Installing Bayanat for: $domain"
    log "Repository: ${BAYANAT_REPO:-$DEFAULT_REPO}"

    # System setup
    _install_system_packages
    _install_uv
    _install_caddy_repo

    # Users and database
    _setup_app_user
    _setup_database

    # Application
    _create_directories

    local tag
    tag=$(latest_remote_tag)
    [[ -n "$tag" ]] || die "No release tags found"
    log "Latest release: $tag"

    _clone_release "$tag"

    if [[ ! -f "$SHARED_DIR/.env" ]]; then
        log "Generating .env..."
        _generate_env "$domain"
    fi

    chown -R "$APP_USER:$APP_USER" "$BAYANAT_ROOT"
    _link_shared "$tag"

    _install_deps "$tag"
    _init_database "$tag"

    # Activate release
    swap_symlink "$RELEASES_DIR/$tag"
    log "Active release: $tag"

    # System integration
    _install_uwsgi_config
    _install_systemd
    _configure_caddy "$domain"
    _install_sudoers

    chown -R "$APP_USER:$APP_USER" "$BAYANAT_ROOT"
    systemctl daemon-reload
    systemctl enable --now bayanat bayanat-celery
    systemctl restart caddy

    _verify_service_health

    log "Installation complete"
    if [[ "$domain" == "localhost" ]]; then
        log "Access: http://$(hostname -I | awk '{print $1}')"
    else
        log "Access: https://$domain"
    fi
}

# --- Health check ---

_verify_service_health() {
    local retries=5
    local delay=2
    log "Verifying services are healthy..."

    for svc in bayanat bayanat-celery caddy; do
        if ! systemctl is-active --quiet "$svc"; then
            warn "Service $svc failed to start"
            journalctl -u "$svc" --no-pager -n 5 >&2
            die "Service $svc is not running" "Check logs: journalctl -u $svc -f"
        fi
    done

    # Wait for app to respond on socket
    local sock="$CURRENT_LINK/bayanat.sock"
    local i
    for ((i=1; i<=retries; i++)); do
        if curl -sf --unix-socket "$sock" http://localhost/ -o /dev/null 2>/dev/null; then
            log "Application responding"
            return 0
        fi
        sleep "$delay"
    done
    warn "Application not responding on socket after $((retries * delay))s (may still be starting)"
}

# --- Status ---

cmd_status() {
    local current
    if current=$(current_version); then
        echo "Current version: $current"
    else
        echo "Current version: not installed"
        return 1
    fi

    local latest
    latest=$(latest_remote_tag)
    echo "Latest release:  $latest"

    if [[ "$current" == "$latest" ]]; then
        echo "Status: up to date"
    else
        echo "Status: update available"
    fi

    echo ""
    echo "Services:"
    for svc in bayanat bayanat-celery caddy; do
        printf "  %-20s %s\n" "$svc" "$(systemctl is-active "$svc" 2>/dev/null || echo 'unknown')"
    done
}

# --- Usage ---

usage() {
    cat << EOF
bayanat $SCRIPT_VERSION - Bayanat server management

Usage: bayanat <command> [options]

Commands:
  install [domain]    Install Bayanat (default: localhost)
  status              Show version and service status

Environment:
  BAYANAT_REPO        GitHub repo (default: sjacorg/bayanat)
EOF
}

# --- Main ---

case "${1:-}" in
    install) shift; cmd_install "$@" ;;
    status)  cmd_status ;;
    -h|--help|help) usage ;;
    *) usage; exit 1 ;;
esac
